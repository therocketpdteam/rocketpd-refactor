# Auto-detect text files and normalize
* text=auto

# Force LF for these file types
*.php text eol=lf
*.json text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf

# Treat binaries as binary (no EOL conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary